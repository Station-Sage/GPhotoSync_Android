<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4FF"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- 타이틀 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📷 GPhotoSync"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#1A237E"
            android:gravity="center"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Google Photos → OneDrive 자동 동기화"
            android:textSize="13sp"
            android:textColor="#666"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- ─────────────────────────────────── -->
        <!-- Google 섹션 -->
        <!-- ─────────────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔴 Google Photos"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#D32F2F"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvGoogleClientId"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Client ID 미설정"
                    android:textSize="12sp"
                    android:textColor="#888"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tvGoogleStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="❌ Google 미인증"
                    android:textSize="14sp"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnGoogleSetup"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="API 설정"
                        android:layout_marginEnd="8dp"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                    <Button
                        android:id="@+id/btnGoogleAuth"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Google 로그인"
                        android:backgroundTint="#D32F2F" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ─────────────────────────────────── -->
        <!-- Microsoft 섹션 -->
        <!-- ─────────────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔵 Microsoft OneDrive"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#1565C0"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvMsClientId"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Client ID 미설정"
                    android:textSize="12sp"
                    android:textColor="#888"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tvMsStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="❌ Microsoft 미인증"
                    android:textSize="14sp"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnMsSetup"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="API 설정"
                        android:layout_marginEnd="8dp"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                    <Button
                        android:id="@+id/btnMsAuth"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Microsoft 로그인"
                        android:backgroundTint="#1565C0" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ─────────────────────────────────── -->
        <!-- 동기화 섹션 -->
        <!-- ─────────────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔄 동기화"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#2E7D32"
                    android:layout_marginBottom="12dp" />

                <ProgressBar
                    android:id="@+id/progressBar"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="두 계정 인증 후 동기화를 시작하세요"
                    android:textSize="13sp"
                    android:textColor="#555"
                    android:layout_marginBottom="16dp" />

                <Button
                    android:id="@+id/btnSync"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="동기화 시작"
                    android:textSize="16sp"
                    android:backgroundTint="#2E7D32"
                    android:enabled="false" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 초기화 버튼 -->
        <Button
            android:id="@+id/btnReset"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🗑️ 인증 정보 초기화"
            android:textColor="#F44336"
            style="@style/Widget.MaterialComponents.Button.TextButton" />

        <!-- 저장 경로 안내 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📁 저장 위치: OneDrive/Pictures/GooglePhotos/YYYY-MM/"
            android:textSize="11sp"
            android:textColor="#999"
            android:gravity="center"
            android:layout_marginTop="8dp" />

    </LinearLayout>
</ScrollView>
