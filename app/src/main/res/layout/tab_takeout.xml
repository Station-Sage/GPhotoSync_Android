<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📦 Google Takeout → OneDrive"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="?colorPrimary"
            android:gravity="center"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Takeout ZIP 파일을 선택하면 압축을 풀어 OneDrive에 업로드합니다"
            android:textSize="12sp"
            android:textColor="?android:textColorSecondary"
            android:gravity="center"
            android:layout_marginBottom="20dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="?android:colorBackground">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1️⃣ Google Takeout에서 사진 내보내기"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Google Photos만 선택 → 내보내기 → ZIP 다운로드"
                    android:textSize="11sp"
                    android:textColor="?android:textColorSecondary"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/btnOpenTakeout"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:text="🌐 Google Takeout 열기"
                    android:textSize="13sp"
                    android:backgroundTint="#4285F4" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#22000000"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2️⃣ 다운받은 ZIP 파일 선택"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/btnSelectZip"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="📁 ZIP 파일 선택"
                    android:textSize="15sp"
                    android:backgroundTint="#1565C0" />

                <TextView
                    android:id="@+id/tvZipInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ZIP 파일을 선택하세요"
                    android:textSize="12sp"
                    android:textColor="?android:textColorSecondary"
                    android:layout_marginTop="8dp" />
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#22000000"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📅 날짜 범위 필터 (선택사항)"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="4dp">
                    <Button
                        android:id="@+id/btnStartDate"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:text="시작일 선택"
                        android:textSize="11sp"
                        android:layout_marginEnd="4dp"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
                    <Button
                        android:id="@+id/btnEndDate"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:text="종료일 선택"
                        android:textSize="11sp"
                        android:layout_marginStart="4dp"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvDateRange"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="전체 기간 (필터 없음)"
                    android:textSize="11sp"
                    android:textColor="?android:textColorSecondary"
                    android:gravity="center"
                    android:layout_marginBottom="4dp" />

                <Button
                    android:id="@+id/btnClearDate"
                    android:layout_width="match_parent"
                    android:layout_height="32dp"
                    android:text="날짜 필터 초기화"
                    android:textSize="10sp"
                    style="@style/Widget.MaterialComponents.Button.TextButton" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="?android:colorBackground">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <ProgressBar
                    android:id="@+id/takeoutProgressBar"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvTakeoutProgress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="12sp"
                    android:textColor="?android:textColorSecondary"
                    android:gravity="end"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvTakeoutStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ZIP 파일을 선택 후 업로드하세요"
                    android:textSize="13sp"
                    android:textColor="?android:textColorPrimary"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="12dp" />

                <Button
                    android:id="@+id/btnStartTakeout"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="🚀 OneDrive에 업로드"
                    android:textSize="15sp"
                    android:backgroundTint="#2E7D32"
                    android:enabled="false" />

                <Button
                    android:id="@+id/btnStopTakeout"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:text="중단"
                    android:textSize="13sp"
                    android:backgroundTint="#F44336"
                    android:layout_marginTop="8dp"
                    android:visibility="gone" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="?android:colorBackground">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📋 실시간 로그"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />
                <ScrollView
                    android:id="@+id/scrollTakeoutLog"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:scrollbars="vertical"
                    android:fadeScrollbars="false">
                    <TextView
                        android:id="@+id/tvTakeoutLog"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="대기 중..."
                        android:textSize="10sp"
                        android:textColor="?android:textColorSecondary"
                        android:fontFamily="monospace" />
                </ScrollView>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
